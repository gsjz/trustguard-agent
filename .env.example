# Copy to .env and edit the values you need.

DEPLOYMENT_MODE=docker

DOCKERHUB_REGISTRY=mirror.ccs.tencentyun.com
TRUSTGUARD_IMAGE_PREFIX=trustguard-
TRUSTGUARD_SKILL_IMAGE_PREFIX=trustguard-skill-

# TRUSTGUARD_NETWORK_PROXY=http://localhost:7890

NPM_CONFIG_REGISTRY=https://registry.npmmirror.com/
UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
UV_EXTRA_INDEX_URL=
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_EXTRA_INDEX_URL=
DEBIAN_MIRROR_URL=https://mirrors.tuna.tsinghua.edu.cn/debian
DEBIAN_SECURITY_MIRROR_URL=https://mirrors.tuna.tsinghua.edu.cn/debian-security
GOPROXY=https://goproxy.cn
ALPINE_MIRROR_URL=https://mirrors.tuna.tsinghua.edu.cn/alpine
RUBYGEMS_MIRROR_URL=https://mirrors.tuna.tsinghua.edu.cn/rubygems/

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=trustguard_agent
MYSQL_USER=trustguard
MYSQL_PASSWORD=trustguard

LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL_ID=gpt-4o-mini

# Anthropic
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL_ID=claude-3-5-sonnet-latest
# ANTHROPIC_VERSION=2023-06-01

EXECUTION_DISPATCH_MODE=http
KB_ENABLED=false
MAX_IN_FLIGHT_SKILLS_PER_TASK=0

# 单次点击“执行/续跑”的运行窗口，秒。到期会保存断点并 PAUSED；0 表示不限制。
ORCH_DEFAULT_RUN_MAX_DURATION_SECONDS=900
